# Envoy web — environment (copy to web/.env.local; never commit secrets)

# ── Demo defaults (public) ──
# Which agent the landing card + "Fund me" point at. #128 is a real ERC-8004
# agent on Celo Mainnet; replace with your own after minting at /create.
NEXT_PUBLIC_DEFAULT_AGENT_ID=128
NEXT_PUBLIC_DEFAULT_CHAIN_ID=42220

# ── Stripe card rail (server-only) ──
# Enables "Pay with card" checkout on the fund page.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Card → cUSD settlement (server-only) ──
# Enables /api/stripe/webhook: after a card payment, the treasury sends cUSD
# on-chain to the agent. STRIPE_WEBHOOK_SECRET is the signing secret from the
# Stripe dashboard webhook endpoint; TREASURY_PRIVATE_KEY funds the settlement.
STRIPE_WEBHOOK_SECRET=
TREASURY_PRIVATE_KEY=

# ── Settlement idempotency store (recommended in production) ──
# The webhook must process each checkout session exactly once. Without a durable
# store it falls back to in-memory dedupe, which is NOT safe across serverless
# instances — two instances could double-settle. Point these at Vercel KV or any
# Upstash Redis (REST). UPSTASH_REDIS_REST_URL/_TOKEN are also accepted.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Turnkey TEE custody (server-only) ──
# Enables the "Turnkey (TEE)" custody option on /create: the agent's signing key
# is generated inside Turnkey's secure enclave (non-exportable) and signs the
# EIP-712 wallet-binding via API — the raw key never reaches the browser. When
# unset, /create silently falls back to self-custody (in-browser, reveal-once).
# Get these from the Turnkey dashboard (API key pair + your organization id).
TURNKEY_API_BASE_URL=https://api.turnkey.com
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=

# Protects the enclave SPENDING endpoints (/api/turnkey/approve, /api/turnkey/pay)
# — these move funds, so they must not be open. Your agent runtime sends it as
# `Authorization: Bearer <secret>`. Unset → OPEN in dev (so the /pay enclave demo
# works locally) but REFUSED in production. Set a strong random value before deploy.
AGENT_RUNTIME_SECRET=
