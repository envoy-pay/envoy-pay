{
  "name": "envoy-pay",
  "version": "0.1.0",
  "description": "Celo-first agent payment SDK: x402 + MPP settlement, ERC-8004 identity, and on-chain spending policy via the EnvoyFacilitator. Optional Solana, Stellar, Stripe, DEX/bridge, and unified-wallet modules via subpath imports.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./contracts": {
      "types": "./dist/types/contracts/index.d.ts",
      "import": "./dist/esm/contracts/index.js",
      "require": "./dist/cjs/contracts/index.js"
    },
    "./identity": {
      "types": "./dist/types/identity/index.d.ts",
      "import": "./dist/esm/identity/index.js",
      "require": "./dist/cjs/identity/index.js"
    },
    "./server": {
      "types": "./dist/types/server/index.d.ts",
      "import": "./dist/esm/server/index.js",
      "require": "./dist/cjs/server/index.js"
    },
    "./wallet": {
      "types": "./dist/types/wallet/index.d.ts",
      "import": "./dist/esm/wallet/index.js",
      "require": "./dist/cjs/wallet/index.js"
    },
    "./monitor": {
      "types": "./dist/types/monitor/index.d.ts",
      "import": "./dist/esm/monitor/index.js",
      "require": "./dist/cjs/monitor/index.js"
    },
    "./requests": {
      "types": "./dist/types/requests/index.d.ts",
      "import": "./dist/esm/requests/index.js",
      "require": "./dist/cjs/requests/index.js"
    },
    "./facilitator": {
      "types": "./dist/types/facilitator/index.d.ts",
      "import": "./dist/esm/facilitator/index.js",
      "require": "./dist/cjs/facilitator/index.js"
    },
    "./ows": {
      "types": "./dist/types/adapters/ows.d.ts",
      "import": "./dist/esm/adapters/ows.js",
      "require": "./dist/cjs/adapters/ows.js"
    },
    "./stripe": {
      "types": "./dist/types/adapters/stripe.d.ts",
      "import": "./dist/esm/adapters/stripe.js",
      "require": "./dist/cjs/adapters/stripe.js"
    },
    "./solana": {
      "types": "./dist/types/solana.d.ts",
      "import": "./dist/esm/solana.js",
      "require": "./dist/cjs/solana.js"
    },
    "./stellar": {
      "types": "./dist/types/stellar.d.ts",
      "import": "./dist/esm/stellar.js",
      "require": "./dist/cjs/stellar.js"
    },
    "./okx": {
      "types": "./dist/types/providers/onchainos.d.ts",
      "import": "./dist/esm/providers/onchainos.js",
      "require": "./dist/cjs/providers/onchainos.js"
    },
    "./bridge": {
      "types": "./dist/types/providers/bridge.d.ts",
      "import": "./dist/esm/providers/bridge.js",
      "require": "./dist/cjs/providers/bridge.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && node scripts/fix-esm-extensions.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "rm -rf dist && npm run build:cjs && npm run build:esm && npm run build:types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "demo": "ts-node --transpile-only examples/autonomous-loop/demo.ts",
    "register:self": "ts-node --transpile-only examples/autonomous-loop/register-self.ts",
    "contracts:compile": "cd contracts && npx hardhat compile",
    "contracts:test": "cd contracts && npx hardhat test",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "envoy",
    "envoy-pay",
    "celo",
    "celo-payments",
    "cusd",
    "ceur",
    "ai-agent-payments",
    "autonomous-agent-payments",
    "agent-to-agent-payments",
    "agentic-commerce",
    "machine-to-machine-payments",
    "x402",
    "x402-protocol",
    "mpp",
    "machine-payments-protocol",
    "402-payment-required",
    "http-402",
    "ai-agent-sdk",
    "ai-agent-financial-identity",
    "agent-wallet",
    "agent-virtual-card",
    "policy-engine",
    "agent-escrow",
    "agent-identity",
    "erc-8004",
    "stripe",
    "circle",
    "usdc",
    "base",
    "arbitrum",
    "optimism",
    "polygon",
    "stellar",
    "solana",
    "evm",
    "multi-chain",
    "langchain",
    "crewai",
    "mcp-server",
    "open-wallet-standard"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Envoy",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/envoy-pay/envoy-pay.git"
  },
  "homepage": "https://github.com/envoy-pay/envoy-pay#readme",
  "bugs": {
    "url": "https://github.com/envoy-pay/envoy-pay/issues"
  },
  "dependencies": {
    "@open-wallet-standard/core": "^1.2.4",
    "axios": "^1.14.0",
    "viem": "^2.47.6"
  },
  "peerDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^13.3.0",
    "stripe": ">=16.0.0"
  },
  "peerDependenciesMeta": {
    "@solana/spl-token": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    },
    "@stellar/stellar-sdk": {
      "optional": true
    },
    "stripe": {
      "optional": true
    }
  },
  "devDependencies": {
    "@selfxyz/agent-sdk": "^0.2.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^13.3.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
