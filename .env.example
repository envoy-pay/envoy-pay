# ASG Pay — Environment Variables
# Copy to .env and fill with your actual keys (NEVER commit .env)

# ── EVM ──
# Private key for the agent wallet (any EVM chain)
AGENT_PRIVATE_KEY=0x_your_private_key_here

# ── Stellar ──
# Stellar secret key (starts with S...)
STELLAR_SECRET_KEY=S_your_stellar_secret_here

# ── Solana ──
# Solana keypair (base58 or JSON array)
SOLANA_SECRET_KEY=your_solana_keypair_here

# ── Stripe MPP ──
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_ACCOUNT_ID=acct_your_id_here
